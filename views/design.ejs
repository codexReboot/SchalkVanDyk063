<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title><%= heading %> | codexReboot | Schalk van Dyk | Web Developer & Designer</title>
		<!-- Preconnect (performance optimization) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Alegreya:ital,wght@0,400..900;1,400..900&family=Caveat:wght@400..700&family=Contrail+One&family=Lalezar&family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Oswald:wght@200..700&display=swap"
			rel="stylesheet" />

		<link rel="stylesheet" href="css/style.css" />
	</head>
	<body class="body body--designPage">
		<main class="main main--designPage">
			<!-- HERO SECTION -->
			<header class="main__header header">
				<%- include('partials/navbar') %>
				<section class="header__heroSection heroSection">
					<figure class="heroSection__figure">
						<img
							class="heroSection__logoImage heroSection__logoImage--designPage"
							src="./img/logo/codexRebootHeroLogo.webp"
							alt="Business logo of Schalk van Dyk t/a codexReboot - Web Designer and Developer of websites and web apps that drive traffic and boost sales." />
					</figure>

					<div class="heroSection__headingAndCtaContainer heroSection__headingAndCtaContainer--designPage">
						<h1 class="heroSection__headingH1 headingH1 headingH1--heroHeading">
							<div class="headingH1__primaryHeading">
								<span class="headingH1__title">
									<span class="headingH1__letterS">S</span>
									<span class="headingH1__lettersTheRest">chalk van Dyk</span>
								</span>
								<span class="headingH1__subtitle headingH1__subtitle--designPage">Website Graphics & <br class="headingH1__subtitleLinebreak" />Visual Support</span>
							</div>
						</h1>
						<p class="heroSection__heroIntro heroSection__heroIntro--designPage paragraph paragraph--heroIntro">
							I provide web design visuals, UI graphics, logos, icons, and banners for websites and web apps across South Africa.
						</p>
						<div class="heroSection__ctaContainer heroSection__ctaContainer--designPage">
							<p class="heroSection__ctaIntroParagraph paragraph paragraph--ctaIntroParagraph">Affordable web-ready designs that make your website look professional and engaging.</p>
							<div class="heroSection__ctaButtonContainer">
								<a class="heroSection__ctaBtn btn btn--primary" href="#services">Request a Quote</a>
								<a class="heroSection__ctaBtn btn btn--secondary" href="#portfolio">View Pricing</a>
							</div>
						</div>
					</div>
				</section>
				<!-- sectionDivider -->
				<svg class="sectionDivider sectionDivider--hero" viewBox="0 0 1440 1000" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
					<g transform="scale(1, -1) translate(0, -1000)">
						<path fill="#1b90d8" d="M0,600 C420,900 1020,200 1440,600 L1440,0 L0,0 Z" />
						<path fill="#f2f2f2" d="M0,500 C400,1000 1040,100 1440,500 L1440,0 L0,0 Z" />
						<path fill="url(#gradientBlue)" d="M0,400 C360,800 1080,0 1440,400 L1440,0 L0,0 Z" />
					</g>
					<defs>
						<linearGradient id="gradientBlue" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="#1b90d8" stop-opacity="0" />
							<stop offset="30%" stop-color="#1b90d8" stop-opacity="0.25" />
							<stop offset="100%" stop-color="#1b90d8" stop-opacity="1" />
						</linearGradient>
						<linearGradient id="gradientWhite" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="#f2f2f2" stop-opacity="0" />
							<stop offset="100%" stop-color="#f2f2f2" stop-opacity="1" />
						</linearGradient>
						<linearGradient id="gradientDarkBlue" x1="0%" y1="0%" x2="0%" y2="100%">
							<stop offset="0%" stop-color="#003049" stop-opacity="0" />
							<stop offset="100%" stop-color="#003049" stop-opacity="1" />
						</linearGradient>
					</defs>
				</svg>
			</header>
			<!-- INTRO -->
			<section class="main__servicesIntroSection servicesIntroSection designPageServicesSection">
				<div id="design" class="linkDiv"></div>
				<div class="servicesIntroSection__sectionHeading sectionHeading">
					<h2 class="servicesIntroSection__headingH2 sectionHeading__headingH2 headingH2 headingH2--getstarted">Graphic Design</h2>
					<hr class="servicesIntroSection__hr sectionHeading__hr hr hr--servicesIntroSection" />
					<p class="servicesIntroSection__headingH2Tagline sectionHeading__headingH2Tagline headingH2Tagline headingH2Tagline--getstarted">improve your design</p>
				</div>

				<p class="servicesIntroSection__paragraph paragraph paragraph--getstarted">
					Improve your website design with clean, modern visuals. Many websites don’t need a full redesign — they just need better visual structure, improved graphics, and consistent design elements.
				</p>

				<p class="servicesIntroSection__paragraph paragraph paragraph--getstarted">
					This service provides website graphics and visual design support to improve the look, clarity, and user experience of your website without the cost of a full design agency. It is ideal for businesses
					that want affordable website design improvements, logo, icons and banners support, and UI graphics as part of their web project.
				</p>
			</section>
			<!-- sectionDivider -->
			<svg class="sectionDivider sectionDivider--designPageServicesSection" viewBox="0 0 1440 1000" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
