				<div id="pricing" class="linkDiv"></div>
				<div class="servicesPricingSection__sectionHeading sectionHeading">
					<h2 class="servicesPricingSection__headingH2 sectionHeading__headingH2 headingH2 headingH2--pricing">Pricing</h2>
					<hr class="servicesPricingSection__hr sectionHeading__hr hr hr--pricingSection" />
					<p class="servicesPricingSection__headingH2Tagline sectionHeading__headingH2Tagline headingH2Tagline headingH2Tagline--pricing">Website Graphics & Visual Support</p>
				</div>

				<div class="servicesPricingSection__servicesPricingCardsContainer">
					<article class="servicesPricingSection__servicesPricingCard servicesPricingCard">
						<div class="servicesPricingCard__shadowWrapper">
							<div class="servicesPricingCard__headingContainer">
								<h3 class="servicesPricingCard__pricingCardHeading headingH3 headingH3 headingH3--pricingCardHeading">
									Small Fix <br class="servicesPricingCard__pricingCardHeadingBreakline" /><span class="servicesPricingCard__pricingCardByline paragraph--pricingCardByline">Estimate: R750</span>
								</h3>
								<hr class="servicesPricingCard__pricingCardHeadingHr" />
