		<main class="contactPage">
			<!-- CONTACT PAGE - HERO SECTION -->
			<header class="main__header header">
				<%- include('partials/navbarContactPage') %>
				<section class="header__heroSection heroSection">
					<figure class="heroSection__figure">
						<img
							class="heroSection__logoImage heroSection__logoImage--designPage"
							src="./img/logo/codexRebootHeroLogo.webp"
							alt="Business logo of Schalk van Dyk t/a codexReboot - Web Designer and Developer of websites and web apps that drive traffic and boost sales." />
					</figure>

					<div class="heroSection__headingAndCtaContainer heroSection__headingAndCtaContainer--contactPage">
						<h1 class="heroSection__headingH1 headingH1 headingH1--heroHeading">
							<div class="headingH1__primaryHeading">
								<span class="headingH1__title">
									<span class="headingH1__letterS">S</span>
									<span class="headingH1__lettersTheRest">chalk van Dyk</span>
								</span>
								<span class="headingH1__subtitle headingH1__subtitle--contactPage">Web Designer & Developer</span>
							</div>
						</h1>
						<p class="heroSection__heroIntro heroSection__heroIntro--contactPage paragraph paragraph--heroIntro">
							Looking to start a website project or redesign your current site? Use this page to <a class="heroSection__pagelink" href="#sendmessage">get in touch</a> directly, request a quote, or ask a
							question. Find all my <a class="heroSection__pagelink" href="#contactinfo">contact details</a> below.
						</p>
						<div class="heroSection__ctaContainer heroSection__ctaContainer--contactPage">
							<p class="heroSection__ctaIntroParagraph paragraph paragraph--ctaIntroParagraph">Send a message to start a project or ask a question — I’ll respond as soon as possible.</p>
							<div class="heroSection__ctaButtonContainer">
								<a class="heroSection__ctaBtn btn btn--primary" href="#contactForm">Send Message</a>
								<a class="heroSection__ctaBtn btn btn--secondary" href="#contactDetails">Contact Info</a>
							</div>
						</div>
					</div>
				</section>
