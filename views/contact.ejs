					<hr class="contactDetailsSection__hr sectionHeading__hr hr hr--contactDetails" />
					<p class="contactDetailsSection__headingH2Tagline sectionHeading__headingH2Tagline headingH2Tagline headingH2Tagline--contactDetails">get in touch now</p>
				</div>

